{
  "expo": {
    "name": "Kairos",
    "slug": "kairos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "kairos",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.kairos.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ランニング記録に現在地を使用します。",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "バックグラウンドランニング記録に現在地を使用します。",
        "NSLocationAlwaysUsageDescription": "バックグラウンドランニング記録に現在地を使用します。",
        "NSCameraUsageDescription": "プロフィール写真の撮影に使用します。",
        "NSMicrophoneUsageDescription": "コーチングの音声メッセージ録音に使用します。",
        "NSPhotoLibraryUsageDescription": "プロフィール写真の選択に使用します。",
        "NSMotionUsageDescription": "ランニング時のステップカウントに使用します。",
        "NSHealthShareUsageDescription": "Apple HealthKit とランニングデータを同期します。",
        "NSHealthUpdateUsageDescription": "ランニングデータを Apple Health に保存します。"
      },
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "app.kairos.mobile",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "RECORD_AUDIO",
        "ACTIVITY_RECOGNITION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "app"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "バックグラウンドランニング記録に現在地を使用します。",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "プロフィール写真の撮影に使用します。"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "プロフィール写真の選択に使用します。",
          "savePhotosPermission": "ランカードを写真に保存します。"
        }
      ],
      [
        "expo-sqlite"
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "aeb10f84-a7a6-4408-847c-356db02a4642"
      },
      "router": {
        "origin": false,
        "root": "app"
      }
    },
    "owner": "jerrysong"
  }
}
