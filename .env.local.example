# =============================================================================
# Kairos v2 — 環境変数一覧
# コピー先: .env.local（git に追加しないこと）
# USE_MOCKS=true でローカル動作可能（外部サービス不要）
# =============================================================================

# ── 開発モード ──────────────────────────────────────────────────────────────
NODE_ENV=development
# USE_MOCKS=true に設定すると LINE / Garmin / PayPay / Stripe なしでローカル動作
USE_MOCKS=true

# ── Supabase / PostgreSQL ────────────────────────────────────────────────────
# IMPORTANT: Prisma は pooler URL (port 6543) + connection_limit=1 必須
# PgBouncer session mode は Prisma と非互換
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# マイグレーション実行時のみ direct URL を使用（port 5432）
DIRECT_URL="postgresql://postgres.xxxx:password@db.xxxx.supabase.co:5432/postgres"

# ── Upstash Redis ────────────────────────────────────────────────────────────
UPSTASH_REDIS_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_TOKEN="xxxx"

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="dev-secret-change-in-production-at-least-32-chars"
# アクセストークン TTL: 15 分（秒）
JWT_ACCESS_TTL_SEC=900
# リフレッシュトークン TTL: 7 日（秒）
JWT_REFRESH_TTL_SEC=604800

# ── LINE ─────────────────────────────────────────────────────────────────────
LINE_CHANNEL_ID="1234567890"
LINE_CHANNEL_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
LINE_CHANNEL_ACCESS_TOKEN="xxxx"
# LINE Login 用チャネル（Messaging API とは別）
LINE_LOGIN_CHANNEL_ID="1234567890"
LINE_LOGIN_CHANNEL_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Apple Sign In ─────────────────────────────────────────────────────────────
APPLE_CLIENT_ID="com.kairos.app"
APPLE_TEAM_ID="XXXXXXXXXX"
APPLE_KEY_ID="XXXXXXXXXX"
# APPLE_PRIVATE_KEY は PEM 形式（改行を \n でエスケープ）
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxx\n-----END PRIVATE KEY-----"

# ── Google Sign In ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxx"

# ── Mapbox ───────────────────────────────────────────────────────────────────
MAPBOX_ACCESS_TOKEN="pk.eyJ1IjoieHh4eCIsImEiOiJ4eHh4In0.xxxx"
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN="pk.eyJ1IjoieHh4eCIsImEiOiJ4eHh4In0.xxxx"
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN="pk.eyJ1IjoieHh4eCIsImEiOiJ4eHh4In0.xxxx"

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_xxxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxx"
# Stripe Connect（コーチ送金）
STRIPE_CONNECT_CLIENT_ID="ca_xxxx"
# JCB は Stripe アカウント設定で明示的に有効化が必要（デフォルト無効）

# ── PayPay ───────────────────────────────────────────────────────────────────
# PayPay 継続課金は自動更新非対応 → QStash 日次バッチで処理
PAYPAY_API_KEY="xxxx"
PAYPAY_API_SECRET="xxxx"
PAYPAY_MERCHANT_ID="xxxx"
# sandbox または production
PAYPAY_ENV="sandbox"

# ── Garmin Connect API ───────────────────────────────────────────────────────
# IMPORTANT: OAuth 1.0a + HMAC-SHA1（OAuth 2.0 ではない）
GARMIN_CONSUMER_KEY="xxxx"
GARMIN_CONSUMER_SECRET="xxxx"

# ── Strava ───────────────────────────────────────────────────────────────────
STRAVA_CLIENT_ID="12345"
STRAVA_CLIENT_SECRET="xxxx"

# ── Cloudflare R2 ────────────────────────────────────────────────────────────
R2_ACCOUNT_ID="xxxx"
R2_ACCESS_KEY_ID="xxxx"
R2_SECRET_ACCESS_KEY="xxxx"
R2_BUCKET_NAME="kairos-uploads"
R2_PUBLIC_URL="https://cdn.kairos.app"

# ── Upstash QStash ───────────────────────────────────────────────────────────
QSTASH_URL="https://qstash.upstash.io"
QSTASH_TOKEN="xxxx"
QSTASH_CURRENT_SIGNING_KEY="sig_xxxx"
QSTASH_NEXT_SIGNING_KEY="sig_xxxx"

# ── Claude API（AIコーチング）────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-xxxx"

# ── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"
SENTRY_ORG="kairos"
SENTRY_PROJECT="kairos-api"
NEXT_PUBLIC_SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"
EXPO_PUBLIC_SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"

# ── PostHog（APPI 準拠 — GPS 座標除外済み）───────────────────────────────────
POSTHOG_API_KEY="phc_xxxx"
NEXT_PUBLIC_POSTHOG_KEY="phc_xxxx"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
EXPO_PUBLIC_POSTHOG_KEY="phc_xxxx"

# ── Firebase Cloud Messaging（Android プッシュ通知）──────────────────────────
FIREBASE_PROJECT_ID="kairos-app"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxx\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxx@kairos-app.iam.gserviceaccount.com"

# ── Railway（API サーバー）────────────────────────────────────────────────────
RAILWAY_PROJECT_ID="xxxx"
RAILWAY_ENVIRONMENT_ID="xxxx"

# ── 公開 URL ─────────────────────────────────────────────────────────────────
API_BASE_URL="http://localhost:3001"
WEB_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"
EXPO_PUBLIC_API_BASE_URL="http://localhost:3001"
